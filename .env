# Web Landing Page Environment Variables Template
# Prefix all client-exposed keys with VITE_ or REACT_APP_ based on your bundler

# ==================== CORE ====================
VITE_API_BASE_URL=https://api.na3eeman.com
VITE_ENVIRONMENT=production

# ==================== MAPS ====================
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ==================== FIREBASE ====================
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id

# ==================== CLOUDFLARE ====================
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
VITE_CLOUDFLARE_ANALYTICS_TOKEN=your-cloudflare-web-analytics-token

# ==================== STRIPE ====================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ==================== TWILIO ====================
VITE_TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-sid
